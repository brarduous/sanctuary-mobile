REVENUECAT_APPLE_KEY=appl_your_revenuecat_apple_key
REVENUECAT_GOOGLE_KEY=goog_your_revenuecat_google_key

# Google Sign-In - Get from Google Cloud Console
# Web client ID (OAuth 2.0 - Web application)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_web_client_id.apps.googleusercontent.com
# iOS client ID (OAuth 2.0 - iOS)
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your_ios_client_id.apps.googleusercontent.com

# For Android DEVELOPER_ERROR, ensure:
# 1. Android client ID is registered in Google Cloud (OAuth 2.0 - Android)
# 2. Your signing certificate SHA-1 fingerprint matches Google Cloud config
#    Get it: cd android && ./gradlew signingReport | grep SHA-1
# 3. Package name (us.sanctuaryapp.app) matches Google Cloud credentials
# 4. Rebuild the app bundle with new credentials
